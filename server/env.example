# Tu mail de Gmail
GMAIL_USER=tumail@gmail.com

# La App Password de 16 caracteres que generas en Google
# (NO es tu contrasena normal de Gmail)
GMAIL_APP_PASSWORD=abcdefghijklmnop

# A que mail llegan las reservas (puede ser el mismo que GMAIL_USER)
MAIL_DESTINO=tumail@gmail.com

# Puerto (en local dejar 3000)
PORT=3000
